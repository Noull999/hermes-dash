# Copia este archivo a tunnel.env y rellena los dos valores.
# tunnel.env está gitignored — nunca se sube al repo.

# Token de Vercel: https://vercel.com/account/tokens (scope: Full Account o el team)
VERCEL_TOKEN=

# Deploy Hook del proyecto hermes-dash:
# Vercel → proyecto hermes-dash → Settings → Git → Deploy Hooks
# Crea uno (branch: main) y pega aquí la URL completa.
DEPLOY_HOOK=

# Opcional: puerto local del backend (por defecto 8080)
# LOCAL_PORT=8080
