[Unit]
Description=Hermes Dashboard API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/hermes-dash/backend
EnvironmentFile=/root/hermes-dash/backend/.env
ExecStart=/root/hermes-dash/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
